# Maintainer: atareao <atareao@atareao.es>
# Contributor: atareao <atareao@atareao.es>

pkgname=mdr-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="TUI markdown renderer with paging"
arch=('x86_64' 'aarch64')
url="https://github.com/atareao/mdr"
license=('MIT')
provides=("$pkgname")
conflicts=("$pkgname")

source_x86_64=("$url/releases/download/v$pkgver/mdr-x86_64-unknown-linux-gnu.tar.gz")
source_aarch64=("$url/releases/download/v$pkgver/mdr-aarch64-unknown-linux-gnu.tar.gz")
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    install -Dm755 mdr "$pkgdir/usr/bin/mdr"
    install -Dm644 "$srcdir/completions/mdr.bash" "$pkgdir/usr/share/bash-completion/completions/mdr"
    install -Dm644 "$srcdir/completions/mdr.zsh" "$pkgdir/usr/share/zsh/site-functions/_mdr"
    install -Dm644 "$srcdir/completions/mdr.fish" "$pkgdir/usr/share/fish/vendor_completions.d/mdr.fish"
}
